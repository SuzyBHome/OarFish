# Strava API – register at https://www.strava.com/settings/api
VITE_STRAVA_CLIENT_ID=your_strava_client_id
VITE_STRAVA_CLIENT_SECRET=your_strava_client_secret

# Garmin Health API – register at https://developer.garmin.com
# Requires a backend redirect handler (see docs/garmin-backend.md)
VITE_GARMIN_CLIENT_ID=your_garmin_client_id
VITE_GARMIN_BACKEND_URL=https://your-backend.example.com
